{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window in local and dev URLs.",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }]
    }
  ]
}
